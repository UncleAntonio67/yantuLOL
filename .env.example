# Backend
ENVIRONMENT=dev
BASE_URL=http://localhost:8000
ADMIN_FRONTEND_BASE_URL=http://localhost:5173

# Database (prod recommend Postgres; dev can keep default sqlite if unset)
DATABASE_URL=postgresql+psycopg://yantu:yantu@localhost:5432/yantu

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720
VIEWER_TOKEN_EXPIRE_MINUTES=15

# Bootstrap first super admin (one-time)
# After first boot, remove these values and restart the server.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_NICKNAME=超管

# Storage (PDF-only)
# If unset, defaults to <project>/backend/storage/source_pdfs
SOURCE_PDF_DIR=
PRODUCT_IMAGE_DIR=


# Cloudflare R2 (S3-compatible) storage (optional)
# If these are set, backend will store PDFs and product cover images in R2 (recommended for Cloud Run).
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_REGION=auto

# Watermark font (important for Chinese)
# If unset, server will try Windows default: C:\Windows\Fonts\msyh.ttc
WATERMARK_FONT_FILE=

# Legal disclaimer (auto-appended to delivery message / email)
LEGAL_DISCLAIMER_TEXT=【法律声明/版权提示】本资料仅限购买者本人学习使用，严禁转载、分享、二次传播或用于商业用途。本资料已写入可追溯水印与访问日志，如发生泄露将依法追责。

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-user@example.com
SMTP_PASSWORD=your-smtp-password-or-app-password
SMTP_FROM=your-user@example.com
SMTP_USE_TLS=true


